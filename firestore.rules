rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function canAccessWorkspace(workspaceId) {
      return request.auth != null
        && request.auth.token.email != null
        && (
          (workspaceId == "luigi-test"
            && request.auth.token.email == "luigi.irons11@gmail.com")
          || (workspaceId == "hairstylr"
            && request.auth.token.email == "gnagna97@hotmail.com")
        );
    }

    match /workspaces/{workspaceId} {
      allow read, write: if canAccessWorkspace(workspaceId);

      match /services/{document=**} {
        allow read, write: if canAccessWorkspace(workspaceId);
      }

      match /availability/{document=**} {
        allow read, write: if canAccessWorkspace(workspaceId);
      }

      match /appointments/{document=**} {
        allow read, write: if canAccessWorkspace(workspaceId);
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
