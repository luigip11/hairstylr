rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email != null
        && (
          request.auth.token.email == "luigi.irons11@gmail.com"
          || request.auth.token.email == "gnagna97@hotmail.com"
        );
    }

    function isValidPublicAppointment() {
      return request.resource.data.keys().hasOnly([
          'customerName',
          'serviceId',
          'serviceName',
          'serviceDurationMinutes',
          'notes',
          'status',
          'scheduledFor',
          'scheduledDateKey',
          'slotLabel',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.customerName is string
        && request.resource.data.customerName.size() > 1
        && request.resource.data.customerName.size() < 80
        && request.resource.data.serviceId is string
        && request.resource.data.serviceName is string
        && request.resource.data.serviceDurationMinutes is int
        && request.resource.data.notes is string
        && request.resource.data.notes.size() < 500
        && request.resource.data.status == 'requested'
        && request.resource.data.scheduledFor is timestamp
        && request.resource.data.scheduledDateKey is string
        && request.resource.data.slotLabel is string
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    match /services/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /availability/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /appointments/{document=**} {
      allow read, update, delete: if isAdmin();
      allow create: if isAdmin() || isValidPublicAppointment();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
